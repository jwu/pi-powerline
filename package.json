{
  "name": "pi-powerline",
  "version": "0.2.3",
  "description": "Powerline-style UI extensions for pi coding agent (custom editor, breadcrumb, footer, header)",
  "homepage": "https://github.com/jwu/pi-powerline#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jwu/pi-powerline.git"
  },
  "type": "module",
  "files": [
    "index.ts",
    "editor.ts",
    "breadcrumb.ts",
    "widget.ts",
    "footer.ts",
    "header.ts",
    "settings.ts"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "powerline",
    "extension"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "test:bun": "bun test",
    "format": "prettier --write '**/*.ts'",
    "format:check": "prettier --check '**/*.ts'",
    "prepare": "husky || true"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://raw.githubusercontent.com/jwu/pi-powerline/refs/heads/main/assets/pi-powerline.png"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
